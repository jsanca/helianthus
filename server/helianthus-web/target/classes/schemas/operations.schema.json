{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://helianthus.dev/schemas/operations.schema.json",
  "title": "Helianthus Operations Catalog",
  "description": "Schema for the Helianthus declarative operations catalog (operations.yml).",
  "type": "object",
  "properties": {
    "app": {
      "type": "object",
      "properties": {
        "name": { "type": "string" }
      }
    },
    "datasources": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "properties": {
          "type": {
            "type": "string",
            "enum": ["postgres", "h2"]
          }
        },
        "required": ["type"]
      }
    },
    "queries": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "properties": {
          "datasource": {
            "type": "string",
            "default": "default"
          },
          "sql": { "type": "string" },
          "parameters": {
            "type": "object",
            "additionalProperties": {
              "type": "object",
              "properties": {
                "type": {
                  "type": "string",
                  "default": "string"
                },
                "required": {
                  "type": "boolean",
                  "default": false
                }
              }
            }
          }
        },
        "required": ["sql"]
      }
    },
    "operations": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "properties": {
          "queryRef": { "type": "string" },
          "query": { "type": "string" },
          "datasource": { "type": "string" },
          "parameters": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "name": { "type": "string" },
                "type": {
                  "type": "string",
                  "default": "string"
                },
                "required": {
                  "type": "boolean",
                  "default": false
                }
              },
              "required": ["name"]
            }
          },
          "security": {
            "type": "object",
            "properties": {
              "roles": {
                "type": "array",
                "items": { "type": "string" }
              },
              "realm": { "type": "string" }
            }
          },
          "configurations": {
            "type": "object",
            "default": { "default": {} },
            "additionalProperties": {
              "type": "object",
              "properties": {
                "security": {
                  "type": "object",
                  "properties": {
                    "roles": {
                      "type": "array",
                      "items": { "type": "string" }
                    },
                    "realm": { "type": "string" }
                  }
                },
                "pipeline": {
                  "type": "array",
                  "items": {
                    "oneOf": [
                      {
                        "type": "object",
                        "properties": {
                          "project": {
                            "type": "array",
                            "items": { "type": "string" }
                          }
                        },
                        "additionalProperties": false
                      },
                      {
                        "type": "object",
                        "properties": {
                          "filter": {
                            "type": "object",
                            "additionalProperties": {
                              "oneOf": [
                                { "type": "string" },
                                { "type": "number" },
                                { "type": "boolean" },
                                { "type": "object" }
                              ]
                            }
                          }
                        },
                        "additionalProperties": false
                      },
                      {
                        "type": "object",
                        "properties": {
                          "limit": { "type": "integer" }
                        },
                        "additionalProperties": false
                      },
                      {
                        "type": "object",
                        "properties": {
                          "derive": {
                            "type": "object",
                            "additionalProperties": { "type": "string" }
                          }
                        },
                        "additionalProperties": false
                      }
                    ]
                  }
                }
              }
            }
          }
        }
      }
    }
  },
  "required": ["operations"]
}
