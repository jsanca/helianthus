<?xml version="1.0" encoding="UTF-8" standalone="yes"?>
<queries>
    <query-config name="/all-products">
        <parameters/>
        <query>SELECT * FROM products ORDER BY id</query>
    </query-config>
    <query-config name="/get-product">
        <parameters>
            <parameter name="productCode" type="string"/>
        </parameters>
        <query>SELECT * FROM products WHERE code = ?</query>
    </query-config>
</queries>
